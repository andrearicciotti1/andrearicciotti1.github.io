---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import Marquee from "../components/Marquee.astro";

const timeline = [
  { year: "1995", title: "Born",                     body: "Rome, Italy." },
  { year: "2016", title: "First steps into directing", body: "Claudio Di Biagio's course La regia e l'idea at Artithesi." },
  { year: "2017", title: "Directorial debut",        body: "Web series Love: Edit, produced by Artithesi and ImageHunters." },
  { year: "2018", title: "SIAE SILLUMINA grant",     body: "Directed CLARK — a short film; a turning point." },
  { year: "2019 — 2023", title: "Trailer cutter",    body: "Cut trailers for Cit Studio." },
  { year: "2019 — 2021", title: "Assistant editor & AD", body: "Bentornato Presidente, Permette Alberto Sordi?, Il Cacciatore S3, Ai Confini del Male." },
  { year: "2021 — 2023", title: "Assembly editor",   body: "Altrimenti ci Arrabbiamo, The Bad Guy, Shake." },
  { year: "2023 — 2024", title: "Lead editor",       body: "Pesci Piccoli (Prime Video), Hanno Ucciso l'Uomo Ragno (Sky)." },
  { year: "2024", title: "Combattere",               body: "Latest directorial work, produced by PunxFilm. Wrapped post in January." },
  { year: "2025 — now",  title: "Current",           body: "Editing Pesci Piccoli S2 and the documentary Benetton Formula." },
];

const facts = [
  { k: "Based in",  v: "Rome, IT" },
  { k: "Languages", v: "Italian · English" },
  { k: "Experience",v: "10+ years" },
  { k: "Tools",     v: "Avid · Premiere · DaVinci" },
  { k: "Rep.",      v: "Self-represented" },
  { k: "Status",    v: "Open to commissions" },
];
---

<BaseLayout title="Bio — Andrea Ricciotti">
  <NavBar active="bio" />

  <!-- HEAD -->
  <section class="head">
    <div class="head__top">
      <span class="mono">§ 03 — Profile</span>
      <span class="mono">Est. 1995 · Rome, IT</span>
    </div>
    <h1 class="head__title display">
      <span>Between</span>
      <span class="serif-italic hot">instinct</span>
      <span>and</span>
      <span class="serif-italic hot">patience.</span>
    </h1>
    <p class="head__lede">
      I cut stories for cinema and streaming, and direct short-form work about
      memory, rupture, and the quiet moments between.
    </p>
  </section>

  <!-- FACTS STRIP -->
  <section class="facts">
    {facts.map((f) => (
      <div class="fact">
        <div class="mono fact__k">{f.k}</div>
        <div class="fact__v display">{f.v}</div>
      </div>
    ))}
  </section>

  <!-- BODY -->
  <section class="body">
    <aside class="body__aside">
      <div class="mono body__label">§ — CV · Highlights</div>
      <div class="downloads">
        <a href="/assets/andrea-ricciotti-cv.pdf" download="Andrea Ricciotti - CV 2025.pdf" class="dl">
          <span class="display">Curriculum Vitae</span>
          <span class="mono">PDF ↓</span>
        </a>
        <a href="https://letterboxd.com/" target="_blank" rel="noopener" class="dl">
          <span class="display">Letterboxd</span>
          <span class="mono">↗</span>
        </a>
        <a href="https://www.imdb.com/it/name/nm10527696/" target="_blank" rel="noopener" class="dl">
          <span class="display">IMDb</span>
          <span class="mono">↗</span>
        </a>
      </div>
    </aside>

    <div class="body__copy">
      <p class="p p--lead">
        <span class="drop">B</span>orn in 1995, I took my first steps into
        directing with Claudio Di Biagio's course
        <span class="serif-italic">La regia e l'idea</span> at Artithesi in 2016.
        My directorial debut came with the web series
        <span class="serif-italic">Love: Edit</span>, produced by
        Artithesi and ImageHunters.
      </p>
      <p class="p">
        After a few years navigating videomaking and filmmaking, I won the
        <span class="serif-italic">SIAE SILLUMINA</span> grant in 2018, directing
        <span class="serif-italic">CLARK</span> — a short film that marked a
        turning point in my career.
      </p>
      <p class="p">
        I sharpened my skills as an assistant editor
        (<span class="serif-italic">Bentornato Presidente</span>,
        <span class="serif-italic">Permette, Alberto Sordi?</span>),
        before stepping onto set as an assistant director
        (<span class="serif-italic">Il Cacciatore S3</span>,
        <span class="serif-italic">Ai Confini del Male</span>).
      </p>
      <p class="p">
        My path led me to assembly editing
        (<span class="serif-italic">Altrimenti ci Arrabbiamo</span>,
        <span class="serif-italic">The Bad Guy</span>,
        <span class="serif-italic">Shake</span>) before taking the lead in the
        cutting room, shaping
        <span class="serif-italic">Pesci Piccoli</span> (Prime Video) and
        <span class="serif-italic">Hanno Ucciso l'Uomo Ragno</span> (Sky, 2024).
      </p>
      <p class="p">
        Between 2019 and 2023, I cut trailers for Cit Studio. My latest
        directorial work, <span class="serif-italic">COMBATTERE</span> —
        produced by PunxFilm — wrapped post-production in January 2024.
        Most recently, I completed <span class="serif-italic">Pesci Piccoli S2</span>
        and the documentary <span class="serif-italic">Benetton Formula</span>.
      </p>
    </div>
  </section>

  <Marquee
    items={["Avid Media Composer", "Adobe Premiere", "DaVinci Resolve", "Pro Tools", "Frame.io"]}
    speed={50}
    invert={true}
    separator="/"
  />

  <!-- TIMELINE -->
  <section class="timeline">
    <header class="timeline__head">
      <span class="mono">§ 04 — Timeline</span>
      <h2 class="display timeline__title">Chronology.</h2>
    </header>
    <ol class="timeline__list">
      {timeline.map((t, i) => (
        <li class="t-row">
          <div class="t-row__n mono">{String(i + 1).padStart(2, "0")}</div>
          <div class="t-row__year mono">{t.year}</div>
          <div class="t-row__title display">{t.title}</div>
          <div class="t-row__body">{t.body}</div>
        </li>
      ))}
    </ol>
  </section>

  <!-- CLOSE -->
  <section class="close">
    <h2 class="close__title display">
      Want to work <span class="serif-italic hot">together?</span>
    </h2>
    <a href="/contact" class="btn btn--hot">
      <span>Send a brief</span><span>→</span>
    </a>
    <div class="close__fine mono">© {new Date().getFullYear()} · Andrea Ricciotti · Rome, IT</div>
  </section>
</BaseLayout>

<style>
  /* HEAD */
  .head {
    padding: clamp(2rem, 4vw, 3rem) var(--gutter) clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: var(--rule-w) solid var(--rule);
  }
  .head__top {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px dashed var(--rule-soft);
    margin-bottom: 1.5rem;
  }
  .head__title {
    font-size: clamp(2.6rem, 8vw, 7.5rem);
    line-height: 0.88;
    color: var(--ink);
  }
  .head__title span { display: inline-block; margin-right: 0.25em; }
  .head__title .serif-italic { text-transform: none; color: var(--hot); }
  .head__lede {
    margin-top: 1.5rem;
    max-width: 58ch;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.5;
    color: var(--ink-mute);
  }

  /* FACTS */
  .facts {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    border-bottom: var(--rule-w) solid var(--rule);
  }
  @media (max-width: 960px) { .facts { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 560px) { .facts { grid-template-columns: repeat(2, 1fr); } }

  .fact {
    padding: 1rem var(--gutter);
    border-right: var(--rule-w) solid var(--rule);
  }
  .fact:last-child { border-right: 0; }
  @media (max-width: 960px) {
    .fact:nth-child(3n) { border-right: 0; }
    .fact:nth-child(-n+3) { border-bottom: var(--rule-w) solid var(--rule); }
  }
  @media (max-width: 560px) {
    .fact:nth-child(2n) { border-right: 0; }
    .fact:nth-child(3n) { border-right: var(--rule-w) solid var(--rule); }
    .fact { border-bottom: var(--rule-w) solid var(--rule); }
    .fact:nth-last-child(-n+2) { border-bottom: 0; }
  }
  .fact__k { color: var(--ink-faint); margin-bottom: 0.25rem; font-size: 0.58rem; }
  .fact__v { font-size: 1.15rem; color: var(--ink); }

  /* BODY */
  .body {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 0;
    border-bottom: var(--rule-w) solid var(--rule);
  }
  @media (max-width: 900px) { .body { grid-template-columns: 1fr; } }

  .body__aside {
    padding: clamp(2rem, 4vw, 3.5rem) var(--gutter);
    border-right: var(--rule-w) solid var(--rule);
    position: sticky;
    top: 64px;
    align-self: start;
    background: var(--paper-dim);
  }
  @media (max-width: 900px) { .body__aside { position: static; border-right: 0; border-bottom: var(--rule-w) solid var(--rule); } }
  .body__label { color: var(--hot); margin-bottom: 1.5rem; }

  .downloads { display: flex; flex-direction: column; gap: 0; }
  .dl {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1rem 0;
    border-top: 1px solid var(--rule-soft);
    transition: color var(--dur-fast) var(--ease), padding var(--dur-fast) var(--ease);
    color: var(--ink);
  }
  .dl:last-child { border-bottom: 1px solid var(--rule-soft); }
  .dl:hover { color: var(--hot); padding-left: 0.5rem; }
  .dl .display { font-size: clamp(1.2rem, 2vw, 1.6rem); }

  .body__copy {
    padding: clamp(2rem, 4vw, 3.5rem) var(--gutter);
    max-width: 74ch;
  }
  .p {
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.6;
    color: var(--ink);
    margin-bottom: 1.25rem;
  }
  .p--lead { font-size: clamp(1.2rem, 1.6vw, 1.4rem); }
  .p .serif-italic { color: var(--hot); }
  .drop {
    font-family: var(--font-display);
    float: left;
    font-size: 4.8em;
    line-height: 0.82;
    padding: 0.08em 0.1em 0 0;
    color: var(--hot);
  }

  /* TIMELINE */
  .timeline {
    padding: clamp(3rem, 6vw, 5rem) var(--gutter);
    border-bottom: var(--rule-w) solid var(--rule);
  }
  .timeline__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--rule-soft);
  }
  .timeline__title {
    font-size: clamp(2rem, 5vw, 4rem);
    color: var(--ink);
    line-height: 0.9;
  }

  .timeline__list { list-style: none; padding: 0; margin: 0; }
  .t-row {
    display: grid;
    grid-template-columns: 2.5rem 10rem 1fr 1.5fr;
    gap: 1rem;
    align-items: baseline;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--rule-soft);
    transition: background var(--dur-fast) var(--ease);
    padding-left: 0.25rem;
    padding-right: 0.25rem;
  }
  .t-row:hover { background: var(--paper-dim); }
  .t-row__n { color: var(--ink-faint); }
  .t-row__year { color: var(--hot); }
  .t-row__title { font-size: clamp(1.1rem, 1.6vw, 1.4rem); color: var(--ink); }
  .t-row__body { color: var(--ink-mute); font-size: 0.95rem; line-height: 1.5; }

  @media (max-width: 820px) {
    .t-row {
      grid-template-columns: 2rem 1fr;
      row-gap: 0.3rem;
    }
    .t-row__year { grid-column: 2; }
    .t-row__title { grid-column: 2; }
    .t-row__body { grid-column: 2; }
  }

  /* CLOSE */
  .close {
    padding: clamp(4rem, 8vw, 7rem) var(--gutter);
    text-align: center;
  }
  .close__title {
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.95;
    color: var(--ink);
    margin-bottom: 2rem;
  }
  .close__title .serif-italic { color: var(--hot); text-transform: none; }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.5rem;
    border: var(--rule-w) solid var(--ink);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 1.05rem;
    transition: all var(--dur-fast) var(--ease);
  }
  .btn--hot { background: var(--hot); color: var(--ink); }
  .btn--hot:hover { background: var(--ink); color: var(--hot); }
  .close__fine { margin-top: 3rem; color: var(--ink-faint); font-size: 0.6rem; }
</style>
