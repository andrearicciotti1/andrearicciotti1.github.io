---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import SocialIcons from "../components/SocialIcons.astro";

const scenes = [
  { title: "Between cuts", tag: "Reel", year: "2024", note: "Editing reel — 90 seconds of rhythm, silence, and recut.", poster: "/assets/projects/nameless-ballad.jpg" },
  { title: "Directing reel", tag: "Reel", year: "2024", note: "Selected frames from Clark, Combattere, and Showu - Kuni.", poster: "/assets/projects/combattere.jpg" },
  { title: "Trailer studies", tag: "Collection", year: "2019 — 2023", note: "Three years at Cit Studio. A selection of trailer cuts.", poster: "/assets/projects/altrimenti.jpg" },
  { title: "B-roll & behind", tag: "Photo", year: "ongoing", note: "On-set polaroids. Avid timelines. Notes from the cutting room.", poster: "/assets/projects/pesci-piccoli-2.jpg" },
];

const writing = [
  { title: "On assembly editing", excerpt: "What a first cut owes the director — and what it doesn't." },
  { title: "The cut as writing", excerpt: "How rhythm becomes narrative, one frame at a time." },
  { title: "Notes from Combattere", excerpt: "Directing a short about inheritance, silence, and footwork." },
];
---

<BaseLayout title="More — Andrea Ricciotti">
  <div class="page">
    <NavBar active="more" />

    <section class="intro">
      <div class="intro__meta mono">
        <span>More</span>
        <span>—</span>
        <span>Scenes, cuts, and other things</span>
      </div>
      <h1 class="intro__headline">
        <span>Scenes</span>
        <span>and</span>
        <span>other things</span>
        <span><em>I've edited</em>.</span>
      </h1>
      <p class="intro__lede">
        Reels, side projects, fragments, notes from the cutting room —
        work that doesn't fit the main filmography, but still matters.
      </p>
    </section>

    <section class="scenes">
      <div class="scenes__label mono">Reels & collections</div>
      <div class="scenes__grid">
        {scenes.map((s, i) => (
          <article class="scene" style={`--i:${i}`}>
            <div class="scene__frame">
              <img src={s.poster} alt={s.title} loading="lazy" />
              <div class="scene__play" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </div>
              <div class="scene__tag mono">{s.tag}</div>
            </div>
            <div class="scene__meta">
              <div class="mono scene__year">{s.year}</div>
              <h3 class="scene__title">{s.title}</h3>
              <p class="scene__note">{s.note}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="notes">
      <div class="notes__header">
        <div class="mono notes__label">Cutting room notes</div>
        <p class="notes__lede">
          Short pieces on craft — drafts from the margin of the timeline.
        </p>
      </div>
      <ol class="notes__list">
        {writing.map((w, i) => (
          <li class="note">
            <div class="mono note__n">{String(i + 1).padStart(2, "0")}</div>
            <div class="note__body">
              <h3 class="note__title">{w.title}</h3>
              <p class="note__excerpt">{w.excerpt}</p>
            </div>
            <div class="mono note__status">Soon</div>
          </li>
        ))}
      </ol>
    </section>

    <section class="etc">
      <div class="etc__grid">
        <a class="etc__card" href="https://letterboxd.com/" target="_blank" rel="noopener">
          <div class="mono etc__k">Letterboxd</div>
          <div class="etc__v">What I'm watching — diary, lists, ratings.</div>
          <div class="etc__arrow">↗</div>
        </a>
        <a class="etc__card" href="https://open.spotify.com/user/1171026149" target="_blank" rel="noopener">
          <div class="mono etc__k">Spotify</div>
          <div class="etc__v">Cutting-room playlists and soundtrack studies.</div>
          <div class="etc__arrow">↗</div>
        </a>
        <a class="etc__card" href="https://www.imdb.com/it/name/nm10527696/" target="_blank" rel="noopener">
          <div class="mono etc__k">IMDb</div>
          <div class="etc__v">Official filmography and credits.</div>
          <div class="etc__arrow">↗</div>
        </a>
      </div>
    </section>

    <section class="closing">
      <div class="closing__sep"></div>
      <h2 class="closing__title">
        Looking for the filmography? <em><a href="/works">Head to Works.</a></em>
      </h2>
      <div class="closing__social"><SocialIcons size={18} /></div>
      <div class="closing__fine mono">© {new Date().getFullYear()} · Andrea Ricciotti · Rome, IT</div>
    </section>
  </div>
</BaseLayout>

<style>
  .page { padding: 0 var(--gutter); max-width: 1600px; margin: 0 auto; }

  .intro {
    padding: clamp(3rem, 10vh, 6rem) 0 clamp(2rem, 5vh, 3.5rem);
    max-width: 1100px;
  }
  .intro__meta {
    color: var(--brass);
    margin-bottom: 2rem;
    display: flex; gap: 0.75rem; flex-wrap: wrap;
  }
  .intro__headline {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 8vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    color: var(--bone);
  }
  .intro__headline span { display: inline-block; margin-right: 0.25em; }
  .intro__headline em { font-style: italic; font-weight: 300; color: var(--brass); }
  .intro__lede {
    margin-top: 1.5rem;
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--bone-dim);
    max-width: 58ch;
    line-height: 1.55;
  }

  /* SCENES */
  .scenes {
    padding: clamp(2rem, 5vh, 4rem) 0;
    border-top: 1px solid var(--ink-700);
  }
  .scenes__label {
    color: var(--brass);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }
  .scenes__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 2.5vw, 2.5rem);
  }
  @media (max-width: 700px) { .scenes__grid { grid-template-columns: 1fr; } }

  .scene { display: flex; flex-direction: column; }
  .scene__frame {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--ink-800);
    border: 1px solid var(--ink-700);
    transition: border-color var(--dur-med) var(--ease);
  }
  .scene:hover .scene__frame { border-color: var(--brass-dim); }
  .scene__frame img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(0.35) contrast(1.02) brightness(0.82);
    transition: filter var(--dur-slow) var(--ease), transform var(--dur-slow) var(--ease);
  }
  .scene:hover .scene__frame img {
    filter: grayscale(0) contrast(1.06) brightness(0.95);
    transform: scale(1.04);
  }
  .scene__play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 64px; height: 64px;
    border: 1px solid var(--bone);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--bone);
    background: rgba(10,10,10,0.4);
    backdrop-filter: blur(4px);
    transition: all var(--dur-med) var(--ease);
  }
  .scene:hover .scene__play {
    border-color: var(--brass);
    color: var(--brass);
    transform: translate(-50%, -50%) scale(1.1);
  }
  .scene__play svg { margin-left: 2px; }
  .scene__tag {
    position: absolute;
    top: 0.75rem; left: 0.75rem;
    background: rgba(10,10,10,0.78);
    color: var(--brass);
    padding: 0.25rem 0.6rem;
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    border: 1px solid rgba(201,165,114,0.22);
    backdrop-filter: blur(6px);
  }
  .scene__meta { padding: 1.1rem 0 0; }
  .scene__year {
    color: var(--brass);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    margin-bottom: 0.5rem;
  }
  .scene__title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1.8vw, 1.6rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--bone);
    margin-bottom: 0.5rem;
    font-variation-settings: "opsz" 48;
  }
  .scene__note {
    font-family: var(--font-serif);
    color: var(--bone-dim);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  /* NOTES */
  .notes {
    padding: clamp(3rem, 8vh, 6rem) 0;
    border-top: 1px solid var(--ink-700);
  }
  .notes__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .notes__label {
    color: var(--brass);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .notes__lede {
    font-family: var(--font-serif);
    color: var(--bone-dim);
    font-size: 0.95rem;
    max-width: 40ch;
    font-style: italic;
  }
  .notes__list { list-style: none; padding: 0; margin: 0; }
  .note {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 2rem;
    align-items: baseline;
    padding: 1.5rem 0;
    border-top: 1px solid var(--ink-700);
    transition: background var(--dur-fast) var(--ease);
  }
  .note:last-child { border-bottom: 1px solid var(--ink-700); }
  .note__n {
    color: var(--brass);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
  }
  .note__title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.6vw, 1.4rem);
    font-weight: 400;
    color: var(--bone);
    margin-bottom: 0.3rem;
    font-variation-settings: "opsz" 48;
  }
  .note__excerpt {
    font-family: var(--font-serif);
    color: var(--bone-dim);
    font-size: 0.95rem;
    line-height: 1.55;
    font-style: italic;
  }
  .note__status {
    color: var(--bone-faint);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border: 1px solid var(--ink-700);
    padding: 0.3rem 0.6rem;
  }
  @media (max-width: 640px) {
    .note { grid-template-columns: auto 1fr; }
    .note__status { grid-column: 2; justify-self: start; margin-top: 0.5rem; }
  }

  /* ETC */
  .etc {
    padding: clamp(3rem, 8vh, 5rem) 0;
    border-top: 1px solid var(--ink-700);
  }
  .etc__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 700px) { .etc__grid { grid-template-columns: 1fr; } }
  .etc__card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.75rem;
    border: 1px solid var(--ink-700);
    background: var(--ink-800);
    position: relative;
    transition: all var(--dur-med) var(--ease);
  }
  .etc__card:hover {
    border-color: var(--brass);
    transform: translateY(-3px);
  }
  .etc__k {
    color: var(--brass);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .etc__v {
    font-family: var(--font-serif);
    color: var(--bone);
    font-size: 1rem;
    line-height: 1.5;
  }
  .etc__arrow {
    position: absolute;
    top: 1.25rem; right: 1.25rem;
    color: var(--bone-faint);
    font-family: var(--font-mono);
    transition: color var(--dur-fast) var(--ease);
  }
  .etc__card:hover .etc__arrow { color: var(--brass); }

  /* CLOSING */
  .closing {
    text-align: center;
    padding: clamp(5rem, 12vh, 9rem) 0 4rem;
    border-top: 1px solid var(--ink-700);
  }
  .closing__sep {
    width: 1px; height: 60px;
    background: var(--brass);
    margin: 0 auto 2rem;
  }
  .closing__title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--bone);
    margin-bottom: 2rem;
  }
  .closing__title em { font-style: italic; color: var(--brass); }
  .closing__title a { color: inherit; border-bottom: 1px solid currentColor; }
  .closing__social { display: flex; justify-content: center; margin-bottom: 3rem; }
  .closing__social :global(.social-icons) { justify-content: center; }
  .closing__fine { color: var(--bone-faint); font-size: 0.62rem; letter-spacing: 0.14em; }
</style>
