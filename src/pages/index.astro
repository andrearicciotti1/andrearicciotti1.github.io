---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import Marquee from "../components/Marquee.astro";
import { projects } from "../data/projects";

const featured = projects.filter((p) => p.featured).slice(0, 6);
const editorCount   = projects.filter((p) => p.roles.includes("Editor")).length;
const directorCount = projects.filter((p) => p.roles.includes("Director")).length;
const writerCount   = projects.filter((p) => p.roles.includes("Writer")).length;
const nowLabel = new Date().toLocaleString("en-US", { weekday: "short", month: "short", day: "2-digit", year: "numeric" });
---

<BaseLayout title="Andrea Ricciotti — Director / Editor">
  <NavBar active="index" />

  <!-- HERO: giant slab -->
  <section class="hero">
    <div class="hero__topline">
      <span class="mono">File · Portfolio / 2019 → 2026</span>
      <span class="mono">{nowLabel} · Rome, IT</span>
    </div>

    <h1 class="hero__title display">
      <span class="line">ANDREA</span>
      <span class="line line--offset">
        <span class="hot">RICCI</span><span class="slash">/</span><span class="hot">OTTI</span>
      </span>
    </h1>

    <div class="hero__split">
      <div class="hero__label">
        <span class="mono">001 — Role</span>
        <h2 class="hero__role display">
          Director<br/>
          <span class="serif-italic role-ital">&amp;</span>
          Editor
        </h2>
      </div>

      <div class="hero__copy">
        <p class="hero__lede">
          I cut stories for cinema and streaming, and direct short-form work
          about memory, rupture, and the quiet moments between.
        </p>
        <p class="hero__lede hero__lede--dim">
          <span class="serif-italic">Selected credits —</span>
          Pesci Piccoli (Prime Video), Hanno Ucciso l'Uomo Ragno (Sky),
          Benetton Formula (Sky), Combattere, Clark.
        </p>
        <div class="hero__cta">
          <a href="/works" class="btn btn--hot">
            <span>View the index</span>
            <span aria-hidden="true">→</span>
          </a>
          <a href="/contact" class="btn btn--ghost">Send a brief</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MARQUEE 1 -->
  <Marquee
    items={["Director", "Editor", "Assembly", "Trailer Cutter", "Writer", "Rome · IT"]}
    speed={45}
    hot={true}
    separator="●"
  />

  <!-- STATS STRIP -->
  <section class="stats">
    <div class="stat">
      <div class="stat__k mono">A · Projects</div>
      <div class="stat__v display">{projects.length}</div>
      <div class="stat__n serif-italic">shipped</div>
    </div>
    <div class="stat">
      <div class="stat__k mono">B · As Editor</div>
      <div class="stat__v display">{String(editorCount).padStart(2,"0")}</div>
      <div class="stat__n serif-italic">credits</div>
    </div>
    <div class="stat">
      <div class="stat__k mono">C · As Director</div>
      <div class="stat__v display">{String(directorCount).padStart(2,"0")}</div>
      <div class="stat__n serif-italic">films</div>
    </div>
    <div class="stat">
      <div class="stat__k mono">D · Experience</div>
      <div class="stat__v display">10+</div>
      <div class="stat__n serif-italic">years</div>
    </div>
  </section>

  <!-- FEATURED REEL: asymmetric slab layout -->
  <section class="reel">
    <header class="reel__header">
      <div class="reel__label">
        <span class="mono">§ 02 —</span>
        <h3 class="display">Selected Reel</h3>
      </div>
      <a href="/works" class="reel__all">All works ({projects.length}) →</a>
    </header>

    <div class="reel__grid">
      {featured.map((p, i) => (
        <a href="/works" class="slate" style={`--i:${i}`} data-idx={String(i+1).padStart(2,"0")}>
          <div class="slate__frame">
            <img src={p.cover} alt={p.title} loading="lazy" />
            <div class="slate__ticker mono">
              <span>◉ REC</span>
              <span class="blink">●</span>
              <span>{String(p.n).padStart(3,"0")}</span>
            </div>
          </div>
          <div class="slate__foot">
            <div class="slate__row">
              <span class="mono">{p.category}{p.platform ? " / " + p.platform : ""}</span>
              <span class="mono">N°{String(p.n).padStart(2,"0")}</span>
            </div>
            <h4 class="slate__title display">{p.title}</h4>
            <div class="slate__credit mono">{p.credit}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- MANIFESTO: oversized type -->
  <section class="manifesto">
    <div class="mono manifesto__label">§ 03 — Manifesto</div>
    <blockquote class="manifesto__q">
      <span class="hot">"</span>The edit is where the film becomes
      <span class="serif-italic">itself</span> — where rhythm meets silence,
      and the director's <span class="serif-italic">instinct</span> meets
      the cutter's <span class="serif-italic">patience</span>. I work both
      sides of that room.<span class="hot">"</span>
    </blockquote>
    <div class="manifesto__sig mono">— A.R. / Rome / Cutting Room 04</div>
  </section>

  <!-- MARQUEE 2 -->
  <Marquee
    items={["Netflix", "Prime Video", "Sky", "Rai Play", "Cinema", "Punx Film", "Cit Studio"]}
    speed={55}
    invert={true}
    separator="/"
  />

  <!-- FOOTER: full-bleed brutalist -->
  <footer class="foot">
    <div class="foot__grid">
      <div class="foot__col">
        <div class="mono foot__label">§ — Get in touch</div>
        <a class="foot__mail display" href="mailto:andrearicciotti1@gmail.com">
          andrearicciotti1<span class="hot">@</span>gmail.com
        </a>
      </div>

      <div class="foot__col">
        <div class="mono foot__label">§ — Elsewhere</div>
        <ul class="foot__list">
          <li><a href="https://www.imdb.com/it/name/nm10527696/" target="_blank" rel="noopener">IMDb ↗</a></li>
          <li><a href="https://www.linkedin.com/in/andrea-ricciotti-3a351b159/" target="_blank" rel="noopener">LinkedIn ↗</a></li>
          <li><a href="https://www.instagram.com/andrea_ricciotti1/" target="_blank" rel="noopener">Instagram ↗</a></li>
          <li><a href="https://open.spotify.com/user/1171026149" target="_blank" rel="noopener">Spotify ↗</a></li>
        </ul>
      </div>

      <div class="foot__col">
        <div class="mono foot__label">§ — Nav</div>
        <ul class="foot__list">
          <li><a href="/works">Works →</a></li>
          <li><a href="/more">More →</a></li>
          <li><a href="/bio">Bio →</a></li>
          <li><a href="/contact">Contact →</a></li>
        </ul>
      </div>

      <div class="foot__col foot__col--meta">
        <div class="mono foot__label">§ — Build</div>
        <div class="mono foot__fine">© {new Date().getFullYear()} Andrea Ricciotti<br/>All rights reserved.<br/>Built ex-novo in Astro.</div>
      </div>
    </div>

    <div class="foot__mega display" aria-hidden="true">A/R — 2026</div>
  </footer>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    padding: clamp(1.5rem, 3vh, 2.5rem) var(--gutter) clamp(2rem, 4vh, 3rem);
    border-bottom: var(--rule-w) solid var(--rule);
    position: relative;
  }
  .hero__topline {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px dashed var(--rule-soft);
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }
  @media (max-width: 520px) { .hero__topline { flex-direction: column; gap: 0.3rem; } }

  .hero__title {
    color: var(--ink);
    font-size: clamp(4rem, 18vw, 16rem);
    font-family: var(--font-display);
    letter-spacing: -0.02em;
    line-height: 0.84;
  }
  .line { display: block; }
  .line--offset {
    padding-left: clamp(0rem, 12vw, 8rem);
    letter-spacing: -0.025em;
  }
  .hot { color: var(--hot); }
  .slash {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    display: inline-block;
    transform: translateY(-0.04em) scaleY(1.15);
    margin: 0 -0.08em;
  }

  .hero__split {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    margin-top: clamp(2rem, 5vw, 3.5rem);
    padding-top: clamp(1.5rem, 3vw, 2.5rem);
    border-top: 1px dashed var(--rule-soft);
  }
  @media (max-width: 820px) { .hero__split { grid-template-columns: 1fr; } }

  .hero__label { position: relative; }
  .hero__role {
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    line-height: 0.92;
    margin-top: 0.5rem;
  }
  .role-ital {
    color: var(--hot);
    font-style: italic;
    margin-right: 0.1em;
  }

  .hero__copy { max-width: 62ch; }
  .hero__lede {
    font-size: clamp(1.15rem, 1.6vw, 1.4rem);
    line-height: 1.5;
    color: var(--ink);
    margin-bottom: 1rem;
  }
  .hero__lede--dim { color: var(--ink-mute); font-size: 1rem; }
  .hero__cta {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.4rem;
    border: var(--rule-w) solid var(--ink);
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1rem;
    letter-spacing: 0.04em;
    transition: all var(--dur-fast) var(--ease);
  }
  .btn--hot {
    background: var(--hot);
    color: var(--ink);
  }
  .btn--hot:hover { background: var(--ink); color: var(--hot); }
  .btn--ghost { background: transparent; color: var(--ink); }
  .btn--ghost:hover { background: var(--ink); color: var(--paper); }

  /* STATS */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: var(--rule-w) solid var(--rule);
  }
  @media (max-width: 720px) { .stats { grid-template-columns: repeat(2, 1fr); } }
  .stat {
    padding: 1.5rem var(--gutter);
    border-right: var(--rule-w) solid var(--rule);
    position: relative;
  }
  .stat:last-child { border-right: 0; }
  @media (max-width: 720px) {
    .stat:nth-child(2) { border-right: 0; }
    .stat:nth-child(1), .stat:nth-child(2) { border-bottom: var(--rule-w) solid var(--rule); }
  }
  .stat__k { margin-bottom: 0.4rem; }
  .stat__v {
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.9;
    color: var(--ink);
    font-family: var(--font-display);
  }
  .stat__n {
    margin-top: 0.2rem;
    font-size: 1.15rem;
    color: var(--hot);
  }

  /* REEL */
  .reel { padding: clamp(3rem, 6vw, 5rem) var(--gutter); border-bottom: var(--rule-w) solid var(--rule); }
  .reel__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--rule-soft);
  }
  .reel__label { display: flex; align-items: baseline; gap: 0.6rem; }
  .reel__label h3 { font-size: clamp(2rem, 5vw, 3.5rem); line-height: 0.9; color: var(--ink); }
  .reel__all {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: var(--rule-w) solid var(--ink);
    padding-bottom: 2px;
    color: var(--ink);
    transition: color var(--dur-fast) var(--ease);
  }
  .reel__all:hover { color: var(--hot); border-color: var(--hot); }

  .reel__grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 860px) { .reel__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .reel__grid { grid-template-columns: 1fr; } }

  .slate { display: flex; flex-direction: column; color: var(--ink); }
  .slate:nth-child(6n+1) { grid-column: span 7; }
  .slate:nth-child(6n+2) { grid-column: span 5; }
  .slate:nth-child(6n+3) { grid-column: span 4; }
  .slate:nth-child(6n+4) { grid-column: span 4; }
  .slate:nth-child(6n+5) { grid-column: span 4; }
  .slate:nth-child(6n)   { grid-column: span 12; }
  @media (max-width: 860px) {
    .slate,
    .slate:nth-child(n) { grid-column: span 1; }
  }

  .slate__frame {
    position: relative;
    aspect-ratio: 16 / 10;
    border: var(--rule-w) solid var(--ink);
    background: var(--ink);
    overflow: hidden;
  }
  .slate:nth-child(6n) .slate__frame { aspect-ratio: 21 / 9; }
  .slate__frame img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(0.5) contrast(1.05);
    transition: filter var(--dur-med) var(--ease), transform var(--dur-med) var(--ease);
  }
  .slate:hover .slate__frame img {
    filter: grayscale(0) contrast(1.08);
    transform: scale(1.03);
  }
  .slate__ticker {
    position: absolute;
    bottom: 0.6rem;
    left: 0.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.55rem;
    background: var(--paper);
    color: var(--ink);
    border: 1px solid var(--ink);
    font-size: 0.58rem;
  }
  .slate__ticker .blink { color: var(--hot); }

  .slate__foot { padding-top: 0.8rem; }
  .slate__row {
    display: flex; justify-content: space-between;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--rule-soft);
    margin-bottom: 0.4rem;
  }
  .slate__title {
    font-size: clamp(1.3rem, 2vw, 1.85rem);
    line-height: 1;
    color: var(--ink);
    transition: color var(--dur-fast) var(--ease);
  }
  .slate:hover .slate__title { color: var(--hot); }
  .slate__credit { margin-top: 0.3rem; color: var(--ink-mute); }

  /* MANIFESTO */
  .manifesto {
    padding: clamp(4rem, 9vw, 8rem) var(--gutter);
    border-bottom: var(--rule-w) solid var(--rule);
    position: relative;
  }
  .manifesto__label { margin-bottom: 2rem; }
  .manifesto__q {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: clamp(1.8rem, 4.5vw, 4.2rem);
    line-height: 1.02;
    letter-spacing: -0.01em;
    max-width: 26ch;
    color: var(--ink);
  }
  .manifesto__q .serif-italic { text-transform: none; color: var(--hot); letter-spacing: 0; }
  .manifesto__q .hot { color: var(--hot); }
  .manifesto__sig { margin-top: 1.5rem; }

  /* FOOTER */
  .foot {
    background: var(--ink);
    color: var(--paper);
    padding: clamp(3rem, 6vw, 5rem) var(--gutter) 0;
    position: relative;
    overflow: hidden;
  }
  .foot__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 2rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(236, 230, 216, 0.2);
  }
  @media (max-width: 820px) { .foot__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .foot__grid { grid-template-columns: 1fr; } }
  .foot__col { display: flex; flex-direction: column; gap: 0.75rem; }
  .foot__label {
    color: var(--hot);
    font-size: 0.65rem;
  }
  .foot__mail {
    font-size: clamp(1.5rem, 3.5vw, 2.6rem);
    line-height: 1;
    color: var(--paper);
    letter-spacing: -0.01em;
  }
  .foot__mail:hover { color: var(--hot); }
  .foot__list { list-style: none; display: flex; flex-direction: column; gap: 0.35rem; }
  .foot__list a {
    color: var(--paper);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: color var(--dur-fast) var(--ease);
  }
  .foot__list a:hover { color: var(--hot); }
  .foot__fine { color: var(--ink-faint); line-height: 1.6; font-size: 0.65rem; }

  .foot__mega {
    font-size: clamp(5rem, 22vw, 22rem);
    line-height: 0.85;
    color: transparent;
    -webkit-text-stroke: 1px rgba(236, 230, 216, 0.35);
    margin: 1.5rem -0.03em -0.12em;
    white-space: nowrap;
    letter-spacing: -0.03em;
  }
</style>
