---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialIcons from "../components/SocialIcons.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";

const totalCount = projects.length;
const directorCount = projects.filter((p) => p.roles.includes("Director")).length;
const editorCount = projects.filter((p) => p.roles.includes("Editor")).length;
const writerCount = projects.filter((p) => p.roles.includes("Writer")).length;
---

<BaseLayout title="Works — Andrea Ricciotti">
  <div class="page">
    <!-- Header -->
    <header class="topbar">
      <a href="/" class="mark">AR</a>
      <nav class="nav">
        <a href="/" class="nav__link mono">Index</a>
        <span class="nav__sep">/</span>
        <a href="/works" class="nav__link mono is-active">Works</a>
      </nav>
      <div class="nav__social"><SocialIcons size={16} /></div>
    </header>

    <!-- Section title -->
    <section class="title-block">
      <div class="title-block__meta mono">
        <span>Selected works</span>
        <span>—</span>
        <span>{totalCount} projects · 2019 — present</span>
      </div>
      <h1 class="title-block__headline">
        <span><em>Works</em>,</span>
        <span>arranged</span>
        <span>like</span>
        <span>film credits.</span>
      </h1>
      <p class="title-block__lede">
        Long-form fiction, documentary, series television, music video, and the occasional trailer.
        Filter by role below.
      </p>
    </section>

    <!-- Filter bar -->
    <div class="filters">
      <button class="filter is-active" data-filter="all">
        <span class="filter__label">All</span>
        <span class="filter__count mono">{totalCount}</span>
      </button>
      <button class="filter" data-filter="Director">
        <span class="filter__label">As Director</span>
        <span class="filter__count mono">{directorCount}</span>
      </button>
      <button class="filter" data-filter="Editor">
        <span class="filter__label">As Editor</span>
        <span class="filter__count mono">{editorCount}</span>
      </button>
      <button class="filter" data-filter="Writer">
        <span class="filter__label">As Writer</span>
        <span class="filter__count mono">{writerCount}</span>
      </button>
    </div>

    <!-- Grid -->
    <main class="grid">
      {projects.map((project, i) => (
        <ProjectCard project={project} index={i} />
      ))}
    </main>

    <!-- Closing / contact CTA -->
    <section class="closing">
      <div class="closing__sep"></div>
      <h2 class="closing__title">
        Have a cut in mind? <em>Let's talk.</em>
      </h2>
      <a href="mailto:andrearicciotti1@gmail.com" class="closing__mail">
        andrearicciotti1@gmail.com
      </a>
      <div class="closing__social"><SocialIcons size={18} /></div>
      <div class="closing__fine mono">© {new Date().getFullYear()} · Andrea Ricciotti · Rome, IT</div>
    </section>
  </div>
</BaseLayout>

<script>
  // Filter logic — vanilla, no framework needed.
  const filters = document.querySelectorAll<HTMLButtonElement>(".filter");
  const cards = document.querySelectorAll<HTMLElement>("[data-roles]");

  filters.forEach((btn) => {
    btn.addEventListener("click", () => {
      const f = btn.dataset.filter!;
      filters.forEach((b) => b.classList.toggle("is-active", b === btn));
      cards.forEach((c, i) => {
        const roles = (c.dataset.roles || "").split(",");
        const match = f === "all" || roles.includes(f);
        if (match) {
          c.removeAttribute("hidden");
          (c as HTMLElement).style.animationDelay = `${i * 35}ms`;
          c.classList.remove("is-filtering-out");
          c.classList.add("is-filtering-in");
        } else {
          c.classList.remove("is-filtering-in");
          c.classList.add("is-filtering-out");
          setTimeout(() => c.setAttribute("hidden", ""), 200);
        }
      });
    });
  });

  // Reveal on scroll
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("visible");
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
  );
  document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
</script>

<style>
  .page {
    padding: 0 var(--gutter);
    max-width: 1600px;
    margin: 0 auto;
  }

  /* TOPBAR */
  .topbar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--ink-700);
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .mark {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    font-variation-settings: "opsz" 14;
  }
  .nav {
    display: flex; gap: 1rem; align-items: center;
    justify-self: center;
  }
  .nav__link {
    color: var(--bone-faint);
    transition: color var(--dur-fast) var(--ease);
  }
  .nav__link:hover { color: var(--bone); }
  .nav__link.is-active { color: var(--bone); }
  .nav__sep { color: var(--bone-faint); font-family: var(--font-mono); font-size: 0.72rem; }
  .nav__social { justify-self: end; }

  /* TITLE BLOCK */
  .title-block {
    padding: clamp(3rem, 10vh, 6rem) 0 clamp(2rem, 5vh, 3.5rem);
    max-width: 1100px;
  }
  .title-block__meta {
    color: var(--brass);
    margin-bottom: 2rem;
    display: flex; gap: 0.75rem; flex-wrap: wrap;
  }
  .title-block__headline {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 8vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    font-weight: 400;
    font-variation-settings: "opsz" 144;
  }
  .title-block__headline span {
    display: inline-block;
    margin-right: 0.25em;
  }
  .title-block__headline em {
    font-style: italic;
    font-weight: 300;
    color: var(--brass);
  }
  .title-block__lede {
    margin-top: 1.5rem;
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--bone-dim);
    max-width: 58ch;
    line-height: 1.55;
  }

  /* FILTERS */
  .filters {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    padding: 1.5rem 0 3rem;
    border-bottom: 1px solid var(--ink-700);
  }
  .filter {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    border: 1px solid var(--ink-700);
    color: var(--bone-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all var(--dur-fast) var(--ease);
  }
  .filter:hover {
    border-color: var(--bone-ghost);
    color: var(--bone);
  }
  .filter.is-active {
    background: var(--bone);
    color: var(--ink-900);
    border-color: var(--bone);
  }
  .filter__count {
    font-size: 0.6rem;
    opacity: 0.6;
  }
  .filter.is-active .filter__count { opacity: 0.5; }

  /* GRID */
  .grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(1.5rem, 2.5vw, 2rem);
    padding: 3rem 0 5rem;
  }

  /* Editorial asymmetric grid: stagger spans by index */
  .grid > :global(*) { grid-column: span 6; }

  /* Feature rows (larger) */
  .grid > :global(*):nth-child(7n + 1),
  .grid > :global(*):nth-child(7n + 4) { grid-column: span 7; }
  .grid > :global(*):nth-child(7n + 2),
  .grid > :global(*):nth-child(7n + 3) { grid-column: span 5; }

  .grid > :global(*):nth-child(7n + 5),
  .grid > :global(*):nth-child(7n + 6),
  .grid > :global(*):nth-child(7n + 7) { grid-column: span 4; }

  @media (max-width: 900px) {
    .grid > :global(*) { grid-column: span 6 !important; }
  }
  @media (max-width: 600px) {
    .grid > :global(*) { grid-column: span 12 !important; }
  }

  /* CLOSING */
  .closing {
    text-align: center;
    padding: clamp(5rem, 12vh, 9rem) 0 4rem;
    border-top: 1px solid var(--ink-700);
  }
  .closing__sep {
    width: 1px; height: 60px;
    background: var(--brass);
    margin: 0 auto 2rem;
  }
  .closing__title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 96;
    color: var(--bone);
    margin-bottom: 2rem;
  }
  .closing__title em {
    font-style: italic;
    color: var(--brass);
  }
  .closing__mail {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--bone-dim);
    border-bottom: 1px solid var(--bone-ghost);
    padding-bottom: 4px;
    margin-bottom: 3rem;
    transition: color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  .closing__mail:hover { color: var(--brass); border-color: var(--brass); }
  .closing__social { display: flex; justify-content: center; margin-bottom: 3rem; }
  .closing__social :global(.social-icons) { justify-content: center; }
  .closing__fine { color: var(--bone-faint); font-size: 0.62rem; letter-spacing: 0.14em; }
</style>
