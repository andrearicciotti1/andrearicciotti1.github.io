---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import Marquee from "../components/Marquee.astro";
---

<BaseLayout title="Contact — Andrea Ricciotti">
  <NavBar active="contact" />

  <!-- HEAD -->
  <section class="head">
    <div class="head__top">
      <span class="mono">§ 04 — Transmit</span>
      <span class="mono"><span class="nav__pulse"></span> Accepting briefs</span>
    </div>
    <h1 class="head__title display">
      <span>Send</span>
      <span class="hot">the</span>
      <span class="serif-italic">signal.</span>
    </h1>
    <p class="head__lede">
      Features, series, docs, trailers, music videos. Drop a line with what
      you're working on — I reply within 48 hours.
    </p>
  </section>

  <!-- FORM + ASIDE -->
  <section class="split">
    <!-- FORM -->
    <form
      class="form"
      action="https://formsubmit.co/andrearicciotti1@gmail.com"
      method="POST"
    >
      <input type="hidden" name="_subject" value="New message from portfolio" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="text" name="_honey" class="hp" tabindex="-1" autocomplete="off" />

      <div class="form__row">
        <label class="field">
          <span class="mono field__k">01 / Name ✱</span>
          <input name="name" required autocomplete="name" placeholder="Your name" />
        </label>
        <label class="field">
          <span class="mono field__k">02 / Email ✱</span>
          <input type="email" name="email" required autocomplete="email" placeholder="you@studio.com" />
        </label>
      </div>

      <label class="field">
        <span class="mono field__k">03 / Project type</span>
        <select name="project">
          <option value="">— select —</option>
          <option>Feature film</option>
          <option>TV series</option>
          <option>Documentary</option>
          <option>Short film</option>
          <option>Trailer</option>
          <option>Music video</option>
          <option>Other</option>
        </select>
      </label>

      <label class="field">
        <span class="mono field__k">04 / Message ✱</span>
        <textarea name="message" rows="7" required placeholder="Scope, timeline, delivery format."></textarea>
      </label>

      <label class="field">
        <span class="mono field__k">05 / Favourite movie <span class="opt">(tiebreaker)</span></span>
        <input name="favourite_movie" placeholder="Optional — a tiebreaker." />
      </label>

      <div class="form__bottom">
        <button type="submit" class="send">
          <span class="display">Send</span>
          <span class="send__arrow">→</span>
        </button>
        <p class="mono form__fine">No tracking · No newsletter · Just a message.</p>
      </div>
    </form>

    <!-- ASIDE -->
    <aside class="aside">
      <div class="aside__block">
        <div class="mono aside__k">§ — Direct</div>
        <a class="aside__mail display" href="mailto:andrearicciotti1@gmail.com">
          andrearicciotti1<span class="hot">@</span>gmail.com
        </a>
      </div>

      <div class="aside__block">
        <div class="mono aside__k">§ — Based in</div>
        <div class="aside__v display">Rome, <span class="serif-italic hot">IT.</span></div>
        <div class="aside__note">Available worldwide for remote cuts and travel-friendly productions.</div>
      </div>

      <div class="aside__block">
        <div class="mono aside__k">§ — Reply within</div>
        <div class="aside__v display">48 h<span class="hot">.</span></div>
      </div>

      <div class="aside__block">
        <div class="mono aside__k">§ — Elsewhere</div>
        <ul class="aside__list">
          <li><a href="https://www.imdb.com/it/name/nm10527696/" target="_blank" rel="noopener">IMDb <span>↗</span></a></li>
          <li><a href="https://www.linkedin.com/in/andrea-ricciotti-3a351b159/" target="_blank" rel="noopener">LinkedIn <span>↗</span></a></li>
          <li><a href="https://www.instagram.com/andrea_ricciotti1/" target="_blank" rel="noopener">Instagram <span>↗</span></a></li>
          <li><a href="https://open.spotify.com/user/1171026149" target="_blank" rel="noopener">Spotify <span>↗</span></a></li>
        </ul>
      </div>
    </aside>
  </section>

  <Marquee
    items={["Let's talk", "Send a brief", "Rome · IT", "andrearicciotti1@gmail.com", "Open 2026"]}
    speed={38}
    hot={true}
    separator="●"
  />

  <footer class="foot mono">
    © {new Date().getFullYear()} · Andrea Ricciotti · Rome, IT
  </footer>
</BaseLayout>

<style>
  /* HEAD */
  .head {
    padding: clamp(2rem, 4vw, 3rem) var(--gutter) clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: var(--rule-w) solid var(--rule);
  }
  .head__top {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px dashed var(--rule-soft);
    margin-bottom: 1.5rem;
  }
  .nav__pulse {
    display: inline-block;
    width: 7px; height: 7px;
    background: var(--hot);
    border-radius: 50%;
    margin-right: 0.4rem;
    vertical-align: 1px;
  }
  .head__title {
    font-size: clamp(3rem, 10vw, 9rem);
    line-height: 0.88;
    color: var(--ink);
  }
  .head__title span { display: inline-block; margin-right: 0.2em; }
  .head__title .hot { color: var(--hot); }
  .head__title .serif-italic { text-transform: none; }
  .head__lede {
    margin-top: 1.5rem;
    max-width: 58ch;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.5;
    color: var(--ink-mute);
  }

  /* SPLIT */
  .split {
    display: grid;
    grid-template-columns: 2fr 1fr;
    border-bottom: var(--rule-w) solid var(--rule);
  }
  @media (max-width: 900px) { .split { grid-template-columns: 1fr; } }

  /* FORM */
  .form {
    padding: clamp(2rem, 4vw, 3rem) var(--gutter);
    border-right: var(--rule-w) solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
  }
  @media (max-width: 900px) { .form { border-right: 0; border-bottom: var(--rule-w) solid var(--rule); } }

  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.3rem;
  }
  @media (max-width: 560px) { .form__row { grid-template-columns: 1fr; } }

  .field { display: flex; flex-direction: column; gap: 0.35rem; }
  .field__k {
    color: var(--ink-faint);
    font-size: 0.6rem;
  }
  .field__k .opt { color: var(--ink-faint); opacity: 0.6; }

  .form input,
  .form select,
  .form textarea {
    background: transparent;
    border: 0;
    border-bottom: var(--rule-w) solid var(--ink);
    padding: 0.65rem 0;
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--ink);
    transition: border-color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
  }
  .form input::placeholder,
  .form textarea::placeholder {
    color: var(--ink-faint);
    font-family: var(--font-serif);
    font-style: italic;
  }
  .form textarea {
    resize: vertical;
    line-height: 1.5;
    min-height: 160px;
    border: var(--rule-w) solid var(--ink);
    padding: 0.85rem 1rem;
  }
  .form input:focus,
  .form textarea:focus,
  .form select:focus {
    outline: none;
    border-color: var(--hot);
    background: var(--paper-dim);
  }
  .form select {
    appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='8' viewBox='0 0 14 8' fill='none' stroke='%23ff3b00' stroke-width='1.8'><path d='M1 1l6 6 6-6'/></svg>");
    background-repeat: no-repeat;
    background-position: right 0.3rem center;
    padding-right: 1.6rem;
    cursor: pointer;
  }
  .form select option { background: var(--paper); color: var(--ink); }

  .hp { position: absolute; left: -9999px; opacity: 0; }

  .form__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .send {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.75rem;
    background: var(--hot);
    color: var(--ink);
    border: var(--rule-w) solid var(--ink);
    font-size: 1.1rem;
    text-transform: uppercase;
    cursor: pointer;
    transition: all var(--dur-fast) var(--ease);
  }
  .send:hover { background: var(--ink); color: var(--hot); }
  .send__arrow { transition: transform var(--dur-fast) var(--ease); }
  .send:hover .send__arrow { transform: translateX(4px); }
  .form__fine { color: var(--ink-faint); font-size: 0.58rem; }

  /* ASIDE */
  .aside {
    padding: clamp(2rem, 4vw, 3rem) var(--gutter);
    background: var(--paper-dim);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .aside__block { display: flex; flex-direction: column; gap: 0.5rem; padding-bottom: 1.3rem; border-bottom: 1px dashed var(--rule-soft); }
  .aside__block:last-child { border-bottom: 0; padding-bottom: 0; }
  .aside__k { color: var(--hot); font-size: 0.6rem; }
  .aside__mail {
    font-size: clamp(1.4rem, 2.6vw, 2rem);
    color: var(--ink);
    line-height: 1;
    transition: color var(--dur-fast) var(--ease);
    letter-spacing: -0.01em;
  }
  .aside__mail:hover { color: var(--hot); }
  .aside__mail .hot { color: var(--hot); }
  .aside__v {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    line-height: 1;
    color: var(--ink);
  }
  .aside__v .hot { color: var(--hot); }
  .aside__v .serif-italic { text-transform: none; }
  .aside__note {
    color: var(--ink-mute);
    font-size: 0.9rem;
    line-height: 1.5;
    max-width: 28ch;
  }
  .aside__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .aside__list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--rule-soft);
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.15rem;
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease), padding var(--dur-fast) var(--ease);
  }
  .aside__list a:hover { color: var(--hot); padding-left: 0.4rem; }
  .aside__list span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-faint);
  }

  /* FOOT */
  .foot {
    text-align: center;
    padding: 2.5rem var(--gutter);
    color: var(--ink-faint);
    font-size: 0.6rem;
  }
</style>
