---
export interface Props {
  active?: "index" | "works" | "more" | "bio" | "contact";
}
const { active = "index" } = Astro.props;

const links = [
  { key: "index",   label: "Index",   href: "/",        n: "00" },
  { key: "works",   label: "Works",   href: "/works",   n: "01" },
  { key: "more",    label: "More",    href: "/more",    n: "02" },
  { key: "bio",     label: "Bio",     href: "/bio",     n: "03" },
  { key: "contact", label: "Contact", href: "/contact", n: "04" },
];
---

<header class="nav">
  <div class="nav__left">
    <a href="/" class="nav__mark" aria-label="Andrea Ricciotti — Home">
      <span class="mark__ar">A/R</span>
      <span class="mark__dot"></span>
      <span class="mono mark__tag">Dir · Ed</span>
    </a>
  </div>

  <nav class="nav__mid" aria-label="Primary">
    {links.map((l) => (
      <a
        href={l.href}
        class:list={["nav__link", { "is-active": active === l.key }]}
      >
        <span class="mono nav__n">{l.n}</span>
        <span class="nav__label">{l.label}</span>
      </a>
    ))}
  </nav>

  <div class="nav__right">
    <span class="mono nav__status">
      <span class="nav__pulse"></span>
      Open to work · 2026
    </span>
  </div>
</header>

<style>
  .nav {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    padding: 0.9rem var(--gutter);
    border-bottom: var(--rule-w) solid var(--rule);
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--paper);
    gap: 2rem;
  }

  /* MARK */
  .nav__mark {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }
  .mark__ar {
    font-family: var(--font-display);
    font-size: 1.45rem;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--ink);
  }
  .mark__dot {
    width: 8px; height: 8px;
    background: var(--hot);
    border-radius: 50%;
  }
  .mark__tag {
    color: var(--ink);
    font-weight: 500;
  }

  /* MID */
  .nav__mid {
    display: flex;
    gap: 0;
    justify-self: center;
    align-items: stretch;
    border-left: var(--rule-w) solid var(--rule);
  }
  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    border-right: var(--rule-w) solid var(--rule);
    color: var(--ink);
    transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
    position: relative;
  }
  .nav__link:hover {
    background: var(--ink);
    color: var(--paper);
  }
  .nav__link:hover .nav__n { color: var(--hot); }
  .nav__link.is-active {
    background: var(--ink);
    color: var(--paper);
  }
  .nav__link.is-active .nav__n { color: var(--hot); }
  .nav__n {
    font-size: 0.6rem;
    color: var(--ink-faint);
  }
  .nav__label {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  /* RIGHT */
  .nav__right { justify-self: end; }
  .nav__status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--ink);
  }
  .nav__pulse {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--hot);
    box-shadow: 0 0 0 0 rgba(255, 59, 0, 0.8);
    animation: pulse 1.8s var(--ease) infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(255,59,0,0.55); }
    70% { box-shadow: 0 0 0 8px rgba(255,59,0,0); }
    100% { box-shadow: 0 0 0 0 rgba(255,59,0,0); }
  }

  @media (max-width: 860px) {
    .nav { grid-template-columns: auto 1fr; row-gap: 0; }
    .nav__right { display: none; }
    .nav__mid { justify-self: end; overflow-x: auto; scrollbar-width: none; }
    .nav__mid::-webkit-scrollbar { display: none; }
    .nav__link { padding: 0.45rem 0.7rem; }
    .nav__label { font-size: 0.9rem; }
  }
  @media (max-width: 520px) {
    .nav { grid-template-columns: auto; }
    .nav__mid { grid-column: 1; margin-top: 0.75rem; border-top: var(--rule-w) solid var(--rule); }
    .mark__tag { display: none; }
  }
</style>
